# PolyEdge Forge live execution profile template
# Usage:
#   1) Copy needed block to your systemd EnvironmentFile or shell env.
#   2) Keep COMMON baseline for every profile.
#   3) Enable LIVE only after shadow checks pass.

############################
# COMMON (always keep)
############################
FORGE_FEV1_RUNTIME_ENABLED=true
FORGE_FEV1_RUNTIME_MARKETS=5m,15m
FORGE_FEV1_RUNTIME_SYMBOL=BTCUSDT
FORGE_FEV1_RUNTIME_LOOP_MS=160
FORGE_FEV1_RUNTIME_FAST_ENABLED=true
FORGE_FEV1_RUNTIME_FAST_LOOP_MS=35
FORGE_FEV1_RUNTIME_FAST_MARGIN=0.08
FORGE_FEV1_RUNTIME_TARGET_PREWARM_MS=45000
FORGE_FEV1_RUNTIME_TARGET_KEEPALIVE_MS=1800
FORGE_FEV1_RUNTIME_EVENT_IDLE_POLL_MS=1200
FORGE_STRATEGY_RUNTIME_EVENT_CACHE_ENABLED=true
FORGE_STRATEGY_RUNTIME_EVENT_BUFFER_MAX_POINTS=140000
FORGE_SNAPSHOT_REDIS_RING_MAX=20000

# Safety gates
FORGE_FEV1_LIVE_ARM_REQUIRED=true
FORGE_FEV1_LIVE_ARMED=false
FORGE_FEV1_LIVE_HARD_KILL=false
FORGE_FEV1_REQUIRE_FIXED_ENTRY_SIZE=true
FORGE_FEV1_FIXED_ENTRY_SIZE_SHARES=5
FORGE_FEV1_LIVE_ALLOW_ADDS=false
FORGE_FEV1_LIVE_MAX_COMPLETED_TRADES=0
# Optional scope cap for one-shot test:
# FORGE_FEV1_LIVE_MAX_COMPLETED_TRADES_BY_SCOPE=SOLUSDT:5m=1
FORGE_FEV1_LIVE_MAX_OPEN_POSITIONS=1

# Execution policy
FORGE_FEV1_MIN_QUOTE_USDC=1.0
FORGE_FEV1_ENTRY_SLIPPAGE_BPS=18
FORGE_FEV1_EXIT_SLIPPAGE_BPS=24
FORGE_FEV1_LIVE_PROFIT_GATE_ENABLED=false
FORGE_FEV1_LIVE_SIGNAL_ENTRY_FRESHNESS_MS=2000
FORGE_FEV1_LIVE_SIGNAL_EXIT_FRESHNESS_MS=5000
FORGE_FEV1_MARKET_BUY_AMOUNT_DECIMALS=2
FORGE_FEV1_ENTRY_FAK_TTL_MS=600
FORGE_FEV1_ENTRY_FAK_CANCEL_AFTER_MS=850
FORGE_FEV1_ENTRY_FAK_SLIPPAGE_BOOST_BPS=14

# Round/target correctness
FORGE_FEV1_LIVE_TARGET_RESOLVE_ATTEMPTS=4
FORGE_FEV1_LIVE_TARGET_RESOLVE_RETRY_MS=120
FORGE_FEV1_LIVE_TARGET_SWITCH_GUARD_MS=2500
FORGE_FEV1_ROUND_TARGET_MATCH_TOLERANCE_MS=5000

############################
# PROFILE A: SHADOW (no real submit)
############################
# Keep this for one-shot functional verification.
FORGE_FEV1_LIVE_EXECUTE=false
FORGE_FEV1_LIVE_ARMED=false

############################
# PROFILE B: CANARY (single-market, 5 shares)
############################
# Enable only after shadow looks clean.
# FORGE_FEV1_RUNTIME_MARKETS=5m
# FORGE_FEV1_LIVE_EXECUTE=true
# FORGE_FEV1_LIVE_ARMED=true
# FORGE_FEV1_RUNTIME_LOOP_MS=140
# FORGE_FEV1_RUNTIME_FAST_LOOP_MS=30
# FORGE_FEV1_ENTRY_SLIPPAGE_BPS=20
# FORGE_FEV1_EXIT_SLIPPAGE_BPS=26

############################
# PROFILE C: FULL (5m + 15m)
############################
# Only after canary succeeds.
# FORGE_FEV1_RUNTIME_MARKETS=5m,15m
# FORGE_FEV1_LIVE_EXECUTE=true
# FORGE_FEV1_LIVE_ARMED=true
# FORGE_FEV1_RUNTIME_LOOP_MS=140
# FORGE_FEV1_RUNTIME_FAST_LOOP_MS=30
