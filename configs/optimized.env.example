# PolyEdge Optimized Configuration
# Place this in /etc/polyedge/env or source before running

# ============================================
# HTTP Connection Pool Optimization
# ============================================
# Pre-warm connections on startup to avoid cold-start latency
export POLYEDGE_HTTP_PREWARM_URLS="https://clob.polymarket.com/health,https://gamma-api.polymarket.com/markets?limit=1,https://api.binance.com/api/v3/ping"

# HTTP connection pool settings
export POLYEDGE_HTTP_POOL_IDLE_PER_HOST=32
export POLYEDGE_HTTP_POOL_IDLE_TIMEOUT_SEC=300
export POLYEDGE_HTTP_TCP_KEEPALIVE_SEC=60

# HTTP/2 keepalive for faster connection reuse
export POLYEDGE_HTTP2_KEEPALIVE_INTERVAL_SEC=10
export POLYEDGE_HTTP2_KEEPALIVE_TIMEOUT_SEC=5

# ============================================
# Execution Optimization
# ============================================
# Order TTL (milliseconds) - shorter = faster cleanup
# Default is 60000ms (1 minute), can reduce for faster strategies

# ACK probe for connection health monitoring
export POLYEDGE_ACK_ONLY_PROBE_URL="https://clob.polymarket.com/health"
export POLYEDGE_ACK_ONLY_PROBE_EVERY=10

# ============================================
# Feed Optimization
# ============================================
# Tokyo relay source universe
export FORGE_SYMBOLS="BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT"
# Ireland recorder market scope:
# - BTC keeps 5m + 15m
# - ETH/SOL/XRP keep 5m only
export FORGE_ACTIVE_SYMBOLS="BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT"
export FORGE_ACTIVE_TFS="5m,15m"
export FORGE_ACTIVE_SYMBOL_TIMEFRAMES="BTCUSDT:5m|15m,ETHUSDT:5m,SOLUSDT:5m,XRPUSDT:5m"
# Ignore stale Tokyo price ticks to prevent writing stale snapshots/settlements.
export FORGE_TOKYO_INPUT_STALE_GUARD_MS=2500

# Market refresh interval (seconds) - reduce to get fresher data
# Default is 120s, can reduce to 30s for faster strategies
# export POLYEDGE_MARKET_REFRESH_SEC=30

# ============================================
# Runtime Optimization (FEV1 / forge)
# ============================================
# Paper runtime always-on by default, live submit must be explicitly enabled.
export FORGE_FEV1_RUNTIME_ENABLED=true
export FORGE_FEV1_LIVE_EXECUTE=false
export FORGE_FEV1_LIVE_ENABLED=false
export FORGE_FEV1_RUNTIME_MARKETS="5m,15m"
export FORGE_FEV1_RUNTIME_LOOP_MS=1200
export FORGE_FEV1_RUNTIME_QUOTE_USDC=1.0
export FORGE_FEV1_RUNTIME_MAX_ORDERS=1
# Optional tiny-order test mode: entry quote follows price probability cents
# e.g. 43c -> 0.43 USDC quote_size.
# export FORGE_FEV1_LIVE_QUOTE_FROM_PRICE=true
# Drain mode: true = no new entries (only exit/reduce), false = normal
export FORGE_FEV1_RUNTIME_DRAIN_ONLY=false

# Live gateway (Rust strategy -> local gateway)
export FORGE_FEV1_GATEWAY_PRIMARY="http://127.0.0.1:9001"
# export FORGE_FEV1_GATEWAY_BACKUP="http://127.0.0.1:9002"
export FORGE_FEV1_GATEWAY_TIMEOUT_MS=2200
export FORGE_FEV1_MIN_QUOTE_USDC=1.0
# For micro-balance testing, you can lower both quote floors to 0.01:
# export FORGE_FEV1_RUNTIME_QUOTE_USDC=0.01
# export FORGE_FEV1_MIN_QUOTE_USDC=0.01
export FORGE_FEV1_ENTRY_SLIPPAGE_BPS=18
export FORGE_FEV1_EXIT_SLIPPAGE_BPS=22
# Executor mode: gateway | rust_sdk
export FORGE_FEV1_EXECUTOR=rust_sdk
# If rust submit path fails on network, fallback once via gateway submit path.
export FORGE_FEV1_RUST_SUBMIT_FALLBACK_GATEWAY=true

# ============================================
# Notifications (Serveré…±Âł)
# ============================================
# Enable if you want runtime anomaly + daily markdown reports.
# export FORGE_SC3_ENABLED=true
# export FORGE_SC3_API_URL="https://15377.push.ft07.com/send/<your-sendkey>.send"
# export FORGE_SC3_TIMEOUT_MS=4000
# export FORGE_SC3_THROTTLE_MS=300000
# export FORGE_SC3_DAILY_REPORT_HOUR_UTC=0

# Use release build for production (not dev)
# RUST_LOG=info for production, RUST_LOG=debug for development
export RUST_LOG=info

# ============================================
# Network Optimization (apply separately)
# ============================================
# Run: sudo bash scripts/network_optimize.sh
# Or manually add to /etc/sysctl.conf:
#   net.ipv4.tcp_fastopen = 3
#   net.core.rmem_max = 16777216
#   net.core.wmem_max = 16777216
#   net.ipv4.tcp_congestion_control = bbr
